# =============================================================
# RemitSwapHook - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# --- Deployer ---
PRIVATE_KEY=0x_your_private_key_here

# --- Network RPC URLs ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# --- Deployment Config ---
FEE_COLLECTOR=0x_your_fee_collector_address

# Compliance type: "allowlist" (default) or "worldcoin"
COMPLIANCE_TYPE=allowlist

# For testnet: mock USDT is deployed automatically
# For mainnet: USDT on Base
# SUPPORTED_TOKEN=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2

# --- Worldcoin (only if COMPLIANCE_TYPE=worldcoin) ---
# WORLD_ID_ROUTER=0x57f928158C3EE7CDad1e4D8642503c4D0201f611
# WORLD_APP_ID=remitswap

# --- Post-Deployment (filled after deploy, used by SetupDemo) ---
# HOOK_ADDRESS=0x...
# COMPLIANCE_ADDRESS=0x...
# PHONE_RESOLVER_ADDRESS=0x...

# --- Block Explorer Verification ---
BASESCAN_API_KEY=your_basescan_api_key
